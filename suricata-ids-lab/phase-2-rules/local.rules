# Local Suricata Rules - suricata-ids-lab
# Author: Fifth Ace Security
# Target network: 192.168.253.0/24

# Rule 1 - Detect ICMP ping (any source to our network)
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping Detected"; itype:8; sid:1000001; rev:1;)

# Rule 2 - Detect nmap SYN scan
alert tcp any any -> $HOME_NET any (msg:"Nmap SYN Scan Detected"; flags:S; threshold:type threshold, track by_src, count 5, seconds 2; sid:1000002; rev:1;)

# Rule 3 - Detect nmap NULL scan
alert tcp any any -> $HOME_NET any (msg:"Nmap NULL Scan Detected"; flags:0; sid:1000003; rev:1;)

# Rule 4 - Detect nmap FIN scan
alert tcp any any -> $HOME_NET any (msg:"Nmap FIN Scan Detected"; flags:F; sid:1000004; rev:1;)

# Rule 5 - Detect SSH brute force
alert tcp any any -> $HOME_NET 22 (msg:"SSH Brute Force Attempt"; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000005; rev:1;)

# Rule 6 - Detect HTTP scan
alert tcp any any -> $HOME_NET 80 (msg:"HTTP Port Scan Detected"; flags:S; sid:1000006; rev:1;)
